# ============================================================================
# WHITELIST (Files to keep despite patterns above)
# ============================================================================
# Keep these important files
!README.md
!LICENSE
!requirements.txt
!setup.py
!pyproject.toml
!MANIFEST.in

# Keep source code
!*.py
!src/*.py

# Keep essential config
!.gitignore
!.gitattributes

# Keep documentation
!docs/*.md
!docs/*.rst
!*.md

# Keep one example model (optional)
# !models/example.pth

# Keep one sample data file for testing (optional)
# !data/sample_patient.csv